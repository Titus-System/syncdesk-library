{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],

    /* React Specifics */
    "jsx": "react-jsx",

    /* Module Resolution */
    "moduleResolution": "bundler",
    "esModuleInterop": true,

    /* Strict Type-Checking */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,

    /* Type Declaration Output */
    "declaration": true,
    "declarationMap": true,

    "rootDir": "./src",
    "outDir": "./dist",
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
